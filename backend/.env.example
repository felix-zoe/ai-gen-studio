# FastAPI 后端 — 环境变量配置
# 复制此文件为 .env 并填入真实值

# 数据库
DATABASE_URL=sqlite:///./app.db

# JWT（SECRET_KEY 自动生成，无需配置）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AES-256-GCM 主密钥（用于加密用户 API Key）
MASTER_ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# 腾讯云 COS（对象存储 — 用于存储生成的图片）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=ai-gen-studio