# ============================================
# AI Gen Studio — 生产环境配置
# 复制此文件为 .env 并填入真实值
# ============================================

# 域名（用于 CORS 配置，不含 https://）
DOMAIN=your-domain.com

# JWT 签名密钥（必须设置！否则每次重启 token 失效）
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JWT 过期时间（分钟，默认 1440 = 24 小时）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AES-256-GCM 主密钥（用于加密用户 API Key，Base64 编码的 32 字节）
# 生成方法: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
MASTER_ENCRYPTION_KEY=

# 腾讯云 COS（对象存储 — 用于存储生成的图片和视频）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-shanghai
COS_BUCKET=
